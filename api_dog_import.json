{
  "api": {
    "name": "ArcGIS Backend API",
    "description": "ArcGIS Backend API for Regulatory Rules, Community Census Data, Sites, and Compliance Calculations",
    "baseUrl": "http://localhost:8000/api",
    "version": "1.0.0",
    "auth": {
      "type": "none"
    }
  },
  "endpoints": [
    {
      "name": "Regulatory Rules - List",
      "method": "GET",
      "path": "/regulatory-rules/rules/",
      "description": "List all regulatory rules with search, filters, sorting, and pagination",
      "parameters": {
        "query": [
          {
            "name": "search",
            "type": "string",
            "description": "Search in rule name and description",
            "required": false
          },
          {
            "name": "year",
            "type": "integer",
            "description": "Filter by census year",
            "required": false
          },
          {
            "name": "program",
            "type": "string",
            "description": "Filter by program (e.g., Paint, Pesticides)",
            "required": false
          },
          {
            "name": "category",
            "type": "string",
            "description": "Filter by category (e.g., HSP)",
            "required": false
          },
          {
            "name": "rule_type",
            "type": "string",
            "description": "Filter by rule type (e.g., Site Requirements)",
            "required": false
          },
          {
            "name": "is_active",
            "type": "boolean",
            "description": "Filter by active status",
            "required": false
          },
          {
            "name": "sort",
            "type": "string",
            "description": "Sort field (name, program, category, etc.)",
            "required": false
          },
          {
            "name": "page",
            "type": "integer",
            "description": "Page number for pagination",
            "required": false
          },
          {
            "name": "limit",
            "type": "integer",
            "description": "Items per page (max 100)",
            "required": false
          }
        ]
      },
      "responses": {
        "200": {
          "description": "Success",
          "schema": {
            "type": "object",
            "properties": {
              "count": {"type": "integer"},
              "next": {"type": "string", "nullable": true},
              "previous": {"type": "string", "nullable": true},
              "results": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "integer"},
                    "name": {"type": "string"},
                    "description": {"type": "string"},
                    "year": {"type": "integer"},
                    "program": {"type": "string"},
                    "category": {"type": "string"},
                    "rule_type": {"type": "string"},
                    "min_population": {"type": "integer"},
                    "max_population": {"type": "integer"},
                    "site_per_population": {"type": "integer"},
                    "base_required_sites": {"type": "integer"},
                    "is_active": {"type": "boolean"}
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Regulatory Rules - Create",
      "method": "POST",
      "path": "/regulatory-rules/rules/",
      "description": "Create a new regulatory rule",
      "parameters": {
        "body": [
          {
            "name": "regulatory_rule",
            "type": "integer",
            "description": "Regulatory rule ID",
            "required": true
          },
          {
            "name": "census_year",
            "type": "integer",
            "description": "Census year ID",
            "required": true
          },
          {
            "name": "program",
            "type": "string",
            "description": "Program name",
            "required": true
          },
          {
            "name": "category",
            "type": "string",
            "description": "Category",
            "required": true
          },
          {
            "name": "rule_type",
            "type": "string",
            "description": "Rule type",
            "required": true
          },
          {
            "name": "min_population",
            "type": "integer",
            "description": "Minimum population",
            "required": true
          },
          {
            "name": "max_population",
            "type": "integer",
            "description": "Maximum population",
            "required": true
          },
          {
            "name": "site_per_population",
            "type": "integer",
            "description": "Sites per population",
            "required": true
          },
          {
            "name": "base_required_sites",
            "type": "integer",
            "description": "Base required sites",
            "required": true
          },
          {
            "name": "is_active",
            "type": "boolean",
            "description": "Active status",
            "required": false
          }
        ]
      },
      "responses": {
        "201": {
          "description": "Created successfully",
          "schema": {
            "type": "object",
            "properties": {
              "id": {"type": "integer"},
              "regulatory_rule": {"type": "integer"},
              "census_year": {"type": "integer"},
              "name": {"type": "string"},
              "description": {"type": "string"},
              "year": {"type": "integer"},
              "program": {"type": "string"},
              "category": {"type": "string"},
              "rule_type": {"type": "string"},
              "min_population": {"type": "integer"},
              "max_population": {"type": "integer"},
              "site_per_population": {"type": "integer"},
              "base_required_sites": {"type": "integer"},
              "is_active": {"type": "boolean"}
            }
          }
        },
        "400": {
          "description": "Validation error",
          "schema": {
            "type": "object",
            "properties": {
              "error": {"type": "string"}
            }
          }
        }
      }
    },
    {
      "name": "Regulatory Rules - Detail",
      "method": "GET",
      "path": "/regulatory-rules/rules/{id}/",
      "description": "Get a specific regulatory rule",
      "parameters": {
        "path": [
          {
            "name": "id",
            "type": "integer",
            "description": "Rule ID",
            "required": true
          }
        ]
      },
      "responses": {
        "200": {
          "description": "Success",
          "schema": {
            "type": "object",
            "properties": {
              "id": {"type": "integer"},
              "name": {"type": "string"},
              "description": {"type": "string"},
              "year": {"type": "integer"},
              "program": {"type": "string"},
              "category": {"type": "string"},
              "rule_type": {"type": "string"},
              "min_population": {"type": "integer"},
              "max_population": {"type": "integer"},
              "site_per_population": {"type": "integer"},
              "base_required_sites": {"type": "integer"},
              "is_active": {"type": "boolean"}
            }
          }
        },
        "404": {
          "description": "Not found",
          "schema": {
            "type": "object",
            "properties": {
              "error": {"type": "string"}
            }
          }
        }
      }
    },
    {
      "name": "Regulatory Rules - Update",
      "method": "PUT",
      "path": "/regulatory-rules/rules/{id}/",
      "description": "Update a regulatory rule",
      "parameters": {
        "path": [
          {
            "name": "id",
            "type": "integer",
            "description": "Rule ID",
            "required": true
          }
        ],
        "body": [
          {
            "name": "program",
            "type": "string",
            "description": "Program name",
            "required": false
          },
          {
            "name": "category",
            "type": "string",
            "description": "Category",
            "required": false
          },
          {
            "name": "rule_type",
            "type": "string",
            "description": "Rule type",
            "required": false
          },
          {
            "name": "min_population",
            "type": "integer",
            "description": "Minimum population",
            "required": false
          },
          {
            "name": "max_population",
            "type": "integer",
            "description": "Maximum population",
            "required": false
          },
          {
            "name": "site_per_population",
            "type": "integer",
            "description": "Sites per population",
            "required": false
          },
          {
            "name": "base_required_sites",
            "type": "integer",
            "description": "Base required sites",
            "required": false
          },
          {
            "name": "is_active",
            "type": "boolean",
            "description": "Active status",
            "required": false
          }
        ]
      },
      "responses": {
        "200": {
          "description": "Updated successfully",
          "schema": {
            "type": "object",
            "properties": {
              "id": {"type": "integer"},
              "name": {"type": "string"},
              "description": {"type": "string"},
              "year": {"type": "integer"},
              "program": {"type": "string"},
              "category": {"type": "string"},
              "rule_type": {"type": "string"},
              "min_population": {"type": "integer"},
              "max_population": {"type": "integer"},
              "site_per_population": {"type": "integer"},
              "base_required_sites": {"type": "integer"},
              "is_active": {"type": "boolean"}
            }
          }
        },
        "400": {
          "description": "Validation error",
          "schema": {
            "type": "object",
            "properties": {
              "error": {"type": "string"}
            }
          }
        },
        "404": {
          "description": "Not found",
          "schema": {
            "type": "object",
            "properties": {
              "error": {"type": "string"}
            }
          }
        }
      }
    },
    {
      "name": "Regulatory Rules - Delete",
      "method": "DELETE",
      "path": "/regulatory-rules/rules/{id}/",
      "description": "Delete a regulatory rule",
      "parameters": {
        "path": [
          {
            "name": "id",
            "type": "integer",
            "description": "Rule ID",
            "required": true
          }
        ]
      },
      "responses": {
        "204": {
          "description": "Deleted successfully"
        },
        "404": {
          "description": "Not found",
          "schema": {
            "type": "object",
            "properties": {
              "error": {"type": "string"}
            }
          }
        }
      }
    },
