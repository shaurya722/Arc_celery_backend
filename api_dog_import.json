    {
      "name": "Compliance Calculations - List",
      "method": "GET",
      "path": "/compliance/",
      "description": "List compliance calculations with filtering and pagination",
      "parameters": {
        "query": [
          {
            "name": "program",
            "type": "string",
            "description": "Filter by program",
            "required": false
          },
          {
            "name": "community",
            "type": "integer",
            "description": "Filter by community ID",
            "required": false
          },
          {
            "name": "census_year",
            "type": "integer",
            "description": "Filter by census year ID",
            "required": false
          },
          {
            "name": "ordering",
            "type": "string",
            "description": "Sort order (e.g., -created_at)",
            "required": false
          },
          {
            "name": "page_size",
            "type": "integer",
            "description": "Items per page",
            "required": false
          }
        ]
      },
      "responses": {
        "200": {
          "description": "Success",
          "schema": {
            "type": "object",
            "properties": {
              "count": {"type": "integer"},
              "next": {"type": "string", "nullable": true},
              "previous": {"type": "string", "nullable": true},
              "results": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "integer"},
                    "community": {"type": "string"},
                    "community_name": {"type": "string"},
                    "census_year": {"type": "integer"},
                    "program": {"type": "string"},
                    "required_sites": {"type": "integer"},
                    "existing_sites": {"type": "integer"},
                    "shortfall": {"type": "integer"},
                    "compliance_rate": {"type": "number"},
                    "created_at": {"type": "string", "format": "date-time"}
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Compliance Calculations - Trigger",
      "method": "POST",
      "path": "/compliance/",
      "description": "Trigger compliance calculation for a community",
      "parameters": {
        "body": [
          {
            "name": "community",
            "type": "integer",
            "description": "Community ID",
            "required": true
          },
          {
            "name": "program",
            "type": "string",
            "description": "Program name (optional)",
            "required": false
          },
          {
            "name": "census_year",
            "type": "integer",
            "description": "Census year ID (optional)",
            "required": false
          }
        ]
      },
      "responses": {
        "202": {
          "description": "Calculation triggered",
          "schema": {
            "type": "object",
            "properties": {
              "message": {"type": "string"},
              "task_id": {"type": "string"},
              "community": {"type": "integer"},
              "program": {"type": "string"},
              "census_year": {"type": "integer"}
            }
          }
        },
        "400": {
          "description": "Validation error",
          "schema": {
            "type": "object",
            "properties": {
              "error": {"type": "string"}
            }
          }
        }
      }
    },
